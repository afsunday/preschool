{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://wodi.cms/page.schema.json",
    "title": "CMS Blueprint",
    "description": "The acceptable shape of a blueprint under resources/cms — the pages, and globals.json. A blueprint seeds the DB; the editor owns the content from then on. `blocks` is the content (an ordered list); `blockTypes` is editor-only schema describing what fields each block type has.",
    "type": "object",
    "additionalProperties": false,
    "required": ["slug", "title", "blocks"],
    "properties": {
        "slug": {
            "type": "string",
            "description": "The page's URL slug. `_globals` is the site chrome — it has blocks but no route.",
            "pattern": "^_?[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "status": { "enum": ["draft", "published"] },
        "meta": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "title": { "type": ["string", "null"] },
                "description": { "type": ["string", "null"] }
            }
        },
        "blocks": {
            "type": "array",
            "description": "The content: this page's blocks, in order.",
            "items": { "$ref": "#/definitions/block" }
        },
        "blockTypes": {
            "type": "object",
            "description": "Editor-only. What fields a block of each type has, so the editor knows how to edit its settings. Carries no data and renders nothing. A page may use its own types plus the globals'.",
            "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["fields"],
                "properties": {
                    "name": { "type": "string" },
                    "group": { "type": "string" },
                    "version": { "type": "integer" },
                    "acceptsChildren": { "type": "boolean" },
                    "fields": { "type": "array" }
                }
            }
        }
    },
    "definitions": {
        "block": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
                "key": {
                    "type": "string",
                    "description": "Stable identity, unique within the page. What `pull` matches on to tell an existing block from a new one. Never rename it — rename `name` instead.",
                    "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                },
                "type": { "type": "string", "minLength": 1 },
                "name": { "type": ["string", "null"] },
                "isVisible": { "type": "boolean" },
                "settings": { "type": "object" },
                "children": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/block" }
                }
            }
        }
    }
}
