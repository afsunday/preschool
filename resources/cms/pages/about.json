        {
            "type": "about_founder",
            "name": "founder",
            "settings": {
                "image_src": "/images/about/founder.jpg",
                "name": "Dr. Mery Osayi, OMN",
                "role": "Founder & Director, WODI",
                "quote": "When I started WODI, I had one vision: to create the kind of early childhood centre I wished had existed for my own children. A place that sees every child <span>fully</span> — not just what they can do, but who they are becoming. Today, I'm incredibly proud of the team we've built and the families who trust us with their most precious people. WODI isn't just a centre. It's a family."
            }
        },
