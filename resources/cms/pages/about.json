{
    "slug": "about",
    "title": "About us",
    "status": "published",
    "meta": {
        "title": null,
        "description": "We are not a holding space. We are an active development environment for children aged 0-5."
    },
    "blocks": [
        {
            "key": "hero",
            "type": "about_hero",
            "name": "hero",
            "settings": {
                "title": "More than daycare — a place to grow.",
                "subtitle": "WODI is not a holding space. It is a warm, active learning environment for children aged 0 to 5, where every day is full of play, discovery, and care.",
                "image_src": "/images/about/hero-collage.jpg",
                "image_alt": "Teacher playing with children"
            }
        },
        {
            "key": "founder",
            "type": "about_founder",
            "name": "founder",
            "settings": {
                "image_src": "/images/about/founder.jpg",
                "name": "Dr. Mery Osayi, OMN",
                "role": "Founder & Director, WODI",
                "quote": "When I started WODI, I had one vision: to create the kind of early childhood centre I wished had existed for my own children. A place that sees every child <span>fully</span> — not just what they can do, but who they are becoming. Today, I'm incredibly proud of the team we've built and the families who trust us with their most precious people. WODI isn't just a centre. It's a family."
            }
        },
        {
            "key": "programs",
            "type": "about_programs",
            "name": "programs",
            "settings": {
                "eyebrow": "Programs and Classes",
                "heading": "Playful programs for growing minds",
                "cta_label": "Enroll Your Child Today",
                "cta_url": "/#admissions",
                "programs": [
                    {
                        "src": "/images/about/program-art.jpg",
                        "alt": "Children's crayon artwork",
                        "body": "Our Toddler program for 18-month to 2-year-olds blends messy art, sensory play, and gentle routines, so little ones build confidence one happy discovery at a time."
                    },
                    {
                        "src": "/images/about/program-drawing.jpg",
                        "alt": "Child drawing on a wall",
                        "body": "In our Preschool room, three- and four-year-olds explore drawing, early writing, and imaginative play that stretches their curiosity and fine-motor skills."
                    },
                    {
                        "src": "/images/about/program-classroom.jpg",
                        "alt": "Children working at classroom tables",
                        "body": "Our Pre-K class helps five-year-olds get ready for school with hands-on numbers, letters, and group projects that make big ideas feel playful."
                    }
                ]
            }
        },
        {
            "key": "nurture",
            "type": "about_nurture",
            "name": "nurture",
            "settings": {
                "eyebrow": "Our approach",
                "heading": "Nurturing young hearts dreams",
                "image_src": "/images/about/nurturing.jpg",
                "image_alt": "Children drawing at a desk",
                "items": [
                    {
                        "accent": "pink",
                        "title": "A safe, loving space",
                        "body": "Every room is warm, secure, and thoughtfully arranged for little explorers. Children settle in quickly because they feel seen, held, and completely at home."
                    },
                    {
                        "accent": "yellow",
                        "title": "Learning through play",
                        "body": "We follow each child's curiosity, turning everyday moments into rich discovery. Play is how young children make sense of their world, so we make plenty of room for it."
                    },
                    {
                        "accent": "cyan",
                        "title": "Qualified, caring educators",
                        "body": "Our teachers are trained in early childhood development and lead with patience and heart. They notice the small wins and celebrate every step a child takes."
                    },
                    {
                        "accent": "green",
                        "title": "Growing confident hearts",
                        "body": "From sharing toys to naming big feelings, we nurture kindness and resilience every day. Children leave WODI curious, capable, and sure of themselves."
                    }
                ]
            }
        },
        {
            "key": "activities",
            "type": "about_activities",
            "name": "activities",
            "settings": {
                "eyebrow": "Learning activities",
                "heading": "Fun activities that inspire young minds",
                "activities": [
                    {
                        "number": "01",
                        "title": "Art & Craft",
                        "src": "/images/about/activity-1.jpg",
                        "body": "Painting, gluing, and hands-on projects let children express big ideas while building fine-motor skills and a real love of creating."
                    },
                    {
                        "number": "02",
                        "title": "Storytelling & Reading",
                        "src": "/images/about/activity-2.jpg",
                        "body": "Daily story circles spark imagination and early language, introducing new words, sounds, and a lifelong love of books."
                    },
                    {
                        "number": "03",
                        "title": "Music & Movement",
                        "src": "/images/about/activity-3.jpg",
                        "body": "Singing, dancing, and rhythm games get little bodies moving while building coordination, listening skills, and plenty of joy."
                    },
                    {
                        "number": "04",
                        "title": "Big games and puzzle",
                        "src": "/images/about/activity-4.jpg",
                        "body": "Puzzles, building blocks, and cooperative games invite children to problem-solve, take turns, and think things through together."
                    }
                ]
            }
        },
        {
            "key": "team",
            "type": "about_team",
            "name": "team",
            "settings": {
                "eyebrow": "Meet our team",
                "heading": "Caring hearts behind every happy child",
                "members": [
                    {
                        "name": "Jodi McDermott",
                        "role": "Grade Teacher",
                        "accent": "pink",
                        "src": "/images/about/teacher-1.png"
                    },
                    {
                        "name": "Lillian Satterfield",
                        "role": "Grade Teacher",
                        "accent": "blue",
                        "src": "/images/about/teacher-2.png"
                    },
                    {
                        "name": "Samuel Becker-Harvey",
                        "role": "Grade Teacher",
                        "accent": "amber",
                        "src": "/images/about/teacher-3.png"
                    },
                    {
                        "name": "Sean Prosacco",
                        "role": "Grade Teacher",
                        "accent": "orange",
                        "src": "/images/about/teacher-4.png"
                    }
                ]
            }
        },
        {
            "key": "testimonial",
            "type": "about_testimonial",
            "name": "testimonial",
            "settings": {
                "image_src": "/images/about/testimonial.jpg",
                "image_alt": "Children in a classroom",
                "quote": "Choosing WODI was the best decision we made for our daughter. She runs through the doors every morning, comes home full of stories, and has grown so confident in her time here. The teachers treat her like their own, and that peace of mind means everything to us.",
                "name": "Sarah Finlay"
            }
        },
        {
