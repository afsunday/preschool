        },
        {
            "key": "testimonial",
            "type": "about_testimonial",
            "name": "testimonial",
            "settings": {
                "image_src": "/images/about/testimonial.jpg",
                "image_alt": "Children in a classroom",
                "quote": "The team at WODI cares with patience, warmth, and purpose. We feel confident knowing our child is learning in a safe and loving environment.",
                "name": "WODI Family"
            }
        },
        {
