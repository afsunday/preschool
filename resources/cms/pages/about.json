{
    "slug": "about",
    "title": "About us",
    "status": "published",
    "meta": {
        "title": null,
        "description": "We are not a holding space. We are an active development environment for children aged 0-5."
    },
    "blocks": [
        {
            "key": "hero",
            "type": "about_hero",
            "name": "hero",
            "settings": {
                "title": "A caring place where children grow with confidence",
                "subtitle": "Learn more about WODI Childcare, our founder's vision, our programs, and the values that guide how we care for every child.",
                "image_src": "/images/about/hero-collage.jpg",
                "image_alt": "Teacher playing with children"
            }
        },
        {
            "key": "founder",
            "type": "about_founder",
            "name": "founder",
            "settings": {
                "image_src": "/images/about/founder.jpg",
                "name": "Dr. Mercy Itohan Osayi (h.c), MSc. BA Mass Communication, HRM, CSW, Immigration Assistant · Canadian Licensed Child Care Operator",
                "role": "Founder & CEO | Women of Dignity International (WODI)",
                "quote": "When I started WODI, I had one vision: to create the kind of early childhood centre I would want for every child. A place where children are seen <span>fully</span>, not only for what they can do, but for who they are becoming. I am proud of the team we have built and grateful for the families who trust us with their most precious people. WODI is more than a centre. It is a family."
            }
        },
        {
            "key": "programs",
            "type": "about_programs",
            "name": "programs",
            "settings": {
                "eyebrow": "Programs & Classes",
                "heading": "Playful programs for growing minds",
                "cta_label": "Discover Our Programs",
                "cta_url": "/#admissions",
                "programs": [
                    {
                        "src": "/images/about/program-art.jpg",
                        "alt": "Children's crayon artwork",
                        "body": "Hands-on art, sensory play, and discovery activities that encourage children to express themselves, try new ideas, and build confidence."
                    },
                    {
                        "src": "/images/about/program-drawing.jpg",
                        "alt": "Child drawing on a wall",
                        "body": "Age-appropriate activities that support language, early math, social skills, routines, and school readiness through play."
                    },
                    {
                        "src": "/images/about/program-classroom.jpg",
                        "alt": "Children working at classroom tables",
                        "body": "Music, movement, stories, puzzles, and group games that help children build coordination, focus, problem-solving, and friendships."
                    }
                ]
            }
        },
        {
            "key": "nurture",
            "type": "about_nurture",
            "name": "nurture",
            "settings": {
                "eyebrow": "Our approach",
                "heading": "Nurturing young hearts and dreams",
                "image_src": "/images/about/nurturing.jpg",
                "image_alt": "Children drawing at a desk",
                "items": [
                    {
                        "accent": "pink",
                        "title": "Safe Belonging",
                        "body": "Every child deserves to feel welcomed, respected, and secure in their learning environment."
                    },
                    {
                        "accent": "yellow",
                        "title": "Joyful Learning",
                        "body": "We use play, stories, music, art, and exploration to make learning meaningful and fun."
                    },
                    {
                        "accent": "cyan",
                        "title": "Growing Confidence",
                        "body": "Children are encouraged to try, ask questions, solve problems, and celebrate progress."
                    },
                    {
                        "accent": "green",
                        "title": "Family Partnership",
                        "body": "We work with families and caregivers so each child is supported at home and at childcare."
                    }
                ]
            }
        },
        {
            "key": "activities",
            "type": "about_activities",
            "name": "activities",
            "settings": {
                "eyebrow": "Learning Activities",
                "heading": "Fun activities that inspire young minds",
                "activities": [
                    {
                        "number": "01",
                        "title": "Art & Craft",
                        "src": "/images/about/activity-1.jpg",
                        "body": "Encourages imagination, fine motor skills, and creative expression."
                    },
                    {
                        "number": "02",
                        "title": "Storytelling & Reading",
                        "src": "/images/about/activity-2.jpg",
                        "body": "Builds vocabulary, listening skills, and a love for books."
                    },
                    {
                        "number": "03",
                        "title": "Music & Movement",
                        "src": "/images/about/activity-3.jpg",
                        "body": "Supports coordination, rhythm, confidence, and joyful participation."
                    },
                    {
                        "number": "04",
                        "title": "Group Games & Puzzles",
                        "src": "/images/about/activity-4.jpg",
                        "body": "Develops teamwork, problem-solving, patience, and focus."
                    }
                ]
            }
        },
        {
            "key": "team",
            "type": "about_team",
            "name": "team",
            "settings": {
                "eyebrow": "Meet our team",
                "heading": "Caring hearts behind every happy child",
                "members": [
                    {
                        "name": "Jodi McDermott",
                        "role": "Grade Teacher",
                        "accent": "pink",
                        "src": "/images/about/teacher-1.png"
                    },
                    {
                        "name": "Lillian Satterfield",
