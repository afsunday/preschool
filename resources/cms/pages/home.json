            "settings": {
                "title": "Where little minds come alive",
                "subtitle": "Children learn best when they feel safe, seen, and free to explore.",
                "lead": "WODI Childcare provides a warm, play-based early learning environment that nurtures curiosity, builds confidence, and supports each child's social, emotional, physical, and cognitive growth.",
                "primary_label": "Enroll Your Child Today",
                "primary_url": "https://regionofwaterloo.onehsn.com/ux_2_0",
                "secondary_label": "Discover Our Programs",
                "secondary_url": "#resources",
                "stats": [
                    {
                        "value": "",
                        "label": "Safe, caring environment"
                    },
                    {
                        "value": "",
                        "label": "Play-based learning"
                    }
                ]
            }
        },
        {
            "key": "features",
            "type": "feature_bar",
            "name": "features",
            "settings": {
                "lead_title": "Safe & Regulated",
                "lead_body": "Care routines, supervision, and daily practices are designed with child safety, well-being, and applicable childcare standards in mind.",
                "features": [
                    {
                        "icon": "boxes",
                        "title": "Built for Development",
                        "body": "Play-based learning experiences support language, social skills, creativity, problem-solving, and school readiness."
                    },
                    {
                        "icon": "users",
                        "title": "Partnering with Families",
                        "body": "We keep families informed, involved, and connected to their child's daily progress and milestones."
                    },
                    {
                        "icon": "megaphone",
                        "title": "Licensed Child Care",
                        "body": "Learn more about our licensing, policies, and family resources."
                    }
                ]
            }
        },
        {
            "key": "about",
            "type": "about_intro",
            "name": "about",
            "settings": {
                "eyebrow": "About us",
                "body": "<p>At WODI Childcare, childhood is joyful, meaningful, and full of discovery. Our educators nurture creativity, confidence, kindness, and curiosity through play-based learning, guided exploration, and caring relationships.</p>",
                "trusted_label": "Trusted by\nWODI families"
            }
        },
        {
            "key": "resources",
            "type": "resource_cards",
            "name": "resources",
            "settings": {
                "heading": "Families & Kids Resources",
                "subheading": "Helpful activities, tips, videos, and downloadable materials to support learning at home."
            }
        },
        {
            "key": "classroom",
            "type": "classroom_split",
            "name": "classroom",
            "settings": {
                "heading": "Learning through play, care, and guided discovery",
                "points": [
                    {
                        "text": "Builds focus and confidence"
                    },
                    {
                        "text": "Encourages positive peer interaction"
                    },
                    {
                        "text": "Supports early problem-solving and concept development"
                    }
                ]
            }
        },
        {
            "key": "admissions",
            "type": "steps",
            "name": "admissions",
            "settings": {
                "heading": "Admissions & Enrolment",
                "subheading": "Applying to WODI Childcare is simple. Start through OneList, choose WODI Childcare, and our team will guide you through the next steps when space becomes available.",
                "steps": [
                    {
                        "icon": "user",
                        "title": "Register on OneList",
                        "body": "Create your family profile and join our central waitlist. It takes only a few minutes and puts your child in line for a spot."
                    },
                    {
                        "icon": "edit",
                        "title": "Select WODI Childcare",
                        "body": "Choose WODI Childcare as your preferred centre and tell us a little about your child's age and ideal start date."
                    },
                    {
                        "icon": "id",
                        "title": "Wait for Confirmation",
                        "body": "When a place opens in the right room, we reach out to confirm enrolment and walk you through everything you need for day one."
                    }
                ]
            }
        },
        {
            "key": "banner",
            "type": "banner_split",
            "name": "banner",
            "settings": {
                "heading": "Growing minds, active bodies",
                "body": "Children enjoy creative activities, movement, games, stories, and guided learning experiences that make each day engaging and fun."
            }
        },
        {
            "key": "testimonial",
            "type": "testimonials",
            "name": "testimonial",
            "settings": {
                "heading": "What <span class=\"text-wodi-pink\">families</span> say",
                "quote": "From day one, the team at WODI treated my daughter like their own. She runs in every morning excited to see her teachers and comes home full of stories. I could not ask for a warmer, safer place for her to grow.",
                "name": "Loretta Renner",
                "role": "Anna's Mum"
            }
        }
    ],
