        {
            "key": "admissions",
            "type": "steps",
            "name": "admissions",
            "settings": {
                "heading": "Admissions & Enrolment",
                "subheading": "Getting your child started at WODI is simple. Here is how enrolment works, from your first application to their very first day.",
                "steps": [
                    {
                        "icon": "user",
                        "title": "Register on One List",
                        "body": "Create your family profile and join our central waitlist. It takes only a few minutes and puts your child in line for a spot."
                    },
                    {
                        "icon": "edit",
                        "title": "Select WODI Daycare",
                        "body": "Choose WODI Daycare as your preferred centre and tell us a little about your child's age and ideal start date."
                    },
                    {
                        "icon": "id",
                        "title": "Get a Spot",
                        "body": "When a place opens in the right room, we reach out to confirm enrolment and walk you through everything you need for day one."
                    }
                ]
            }
        },
        {
            "key": "banner",
            "type": "banner_split",
            "name": "banner",
            "settings": {
                "heading": "Growing minds, active brains. Children will enjoy a fun-filled games and online activities",
                "body": "Children will be tested with their knowledge skills via trivia games for kids activities like never before"
            }
        },
        {
            "key": "testimonial",
            "type": "testimonials",
            "name": "testimonial",
            "settings": {
                "heading": "What <span class=\"text-wodi-pink\">parents</span> say",
                "quote": "From day one, the team at WODI treated my daughter like their own. She runs in every morning excited to see her teachers and comes home full of stories. I could not ask for a warmer, safer place for her to grow.",
                "name": "Loretta Renner",
                "role": "Anna's Mum"
            }
        }
